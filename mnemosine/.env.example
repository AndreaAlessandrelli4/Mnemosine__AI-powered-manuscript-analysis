# ──────────────────────────────────────────────
# Mnemosine — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.

# ── Inference Provider ──────────────────────
# "openai" (default, for demo/testing) or "hf" (local HuggingFace models)
INFERENCE_PROVIDER=openai

# ── OpenAI Configuration ───────────────────
OPENAI_API_KEY=your_key_here
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_OUTPUT_TOKENS=1200

# ── Manuscripts Root ───────────────────────
# Root directory containing manuscript folders.
# All browse/analyze operations are restricted to this path.
MANUSCRIPTS_ROOT=./manuscripts

# ── Device Configuration ───────────────────
# Allowed devices for inference: auto, cpu, cuda, mps
ALLOWED_DEVICES=auto,cpu,cuda,mps

# ── Prompt Directory ───────────────────────
# Path to directory containing prompt .txt files
PROMPT_DIR=../prompt

# ── Server ─────────────────────────────────
HOST=0.0.0.0
PORT=8000
